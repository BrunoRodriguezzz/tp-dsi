    @startuml
'Hecho
Hecho --> Contribuyente
Hecho --> Origen
Hecho --> Categoria
Hecho --> Ubicacion
Hecho -->"*" Etiqueta
Hecho --o Coleccion
Hecho --> ContenidoMultimedia

'Solicitudes de Eliminacion
SolicitudEliminacion --* Hecho
SolicitudEliminacion --> EstadoSolicitudEliminacion

'Colecciones
Coleccion --> Criterio
Coleccion ..> Filtro

'Importador de Hechos
Coleccion <.. ImportadorHechos

'Criterio
Criterio --> Filtro

'ElementoCriterio
Filtro <|.. FiltroTitulo
Filtro <|.. FiltroCategoria
Filtro <|.. FiltroFechaAcontecimiento

'Estrategias
FiltroCategoria --> Categoria
FiltroFechaAcontecimiento --> RangoFechas

'Contenido Multimedia
ContenidoMultimedia --> Formato

class Contribuyente {
    -nombre: String
    -apellido:
    -edad: Integer
}

enum EstadoSolicitudEliminacion {
    ACEPTADA,
    RECHAZADA,
    PENDIENTE
}

class ContenidoMultimedia {
    -nombre: String
    -ruta: String
    -formato: Formato
}

enum Formato {
    VIDEO
    AUDIO
    IMAGEN
}

class Hecho {
    -titulo: String
    -descripcion: String
    -categoria: Categoria
    -ubicacion: Ubicacion
    -etiquetas: <List>Etiqueta
    -fechaAcontecimiento: LocalDate
    -fechaCarga: LocalDate
    -origen: Origen
    -eliminado: Boolean
    -contenidoMultimedia: List<ContenidoMultimedia>
    +eliminar(): Void
    +tieneContenidoMultimedia(): Boolean
    +estaEliminado(): Boolean
}

class ImportadorHechos {
    -rutaArchivo: String
    +cargarColeccion(Coleccion coleccion, List<Hecho> hechos): Integer
}

class Etiqueta {
    -titulo: String
}

enum Origen {
    MANUAL
    DATASET
    CONTRIBUYENTE
}

class Categoria {
    -titulo: String
}

class Ubicacion {
    -latitud: String
    -longitud: String
}

class SolicitudEliminacion {
    -hecho: Hecho
    -fundamento: String
    -rechazada: Boolean
    -fechaResolucion: LocalDate
    +serAceptada(): Void
    +serRechazada(): Void
}

class Coleccion {
    -hechos: <List> Hecho
    -titulo: String
    -descripcion: String
    -criterio: Criterio
    +agregarHecho(hecho: Hecho): Boolean
    +eliminarHecho(hecho: Hecho): Boolean
    'Solo para representar overload
    +consultarHechos(): <List> Hecho
    +consultarHechos(filtros: <List> Filtro): <List> Hecho
    +recalcularHechos(): Void
}

class Criterio{
    -filtros: <List> Filtro

    +cumpleCriterio(hecho: Hecho): Boolean
    +agregarFiltro((Filtro filtro): Void
}

class RangoFechas {
    -fechaInicio: LocalDate
    -fechaFin: LocalDate
    +coincide(date: LocalDate): Boolean
}

interface Filtro{
    +coincide(algo): Boolean
}

class FiltroTitulo{
    -titulo: String
    +coincide(algo): Boolean
}

class FiltroFechaAcontecimiento{
    -fechaAcontecimientoEntre: RangoFechas
    +coincide(algo): Boolean
}

class FiltroCategoria{
    -categoria: Categoria
    +coincide(algo): Boolean
}

@enduml