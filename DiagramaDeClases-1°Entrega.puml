    @startuml
'Hecho
Hecho --> Contribuyente
Hecho --> Origen
Hecho --> Categoria
Hecho --> Ubicacion
Hecho -->"*" Etiqueta
Hecho --o Coleccion

SolicitudEliminacion --* Hecho

Coleccion --> Criterio

'Criterio
Criterio --> ElementoCriterio

'ElementoCriterio
ElementoCriterio <|.. ElementoCriterioTitulo
ElementoCriterio <|.. ElementoCriterioCategoria
ElementoCriterio <|.. ElementoCriterioFechaAcontecimiento

'Estrategias
EstrategiaCategoria --> Categoria
EstrategiaUbicacion --> Ubicacion
EstrategiaFechaAcontecimiento --> RangoFechas
EstrategiaFechaCarga --> RangoFechas
EstrategiaOrigen --> Origen

SolicitudEliminacion --> EstadoSolicitudEliminacion

ContenidoMultimedia --> Formato
Hecho --> ContenidoMultimedia
Coleccion <.. ImportadorHechos

class Contribuyente {
    -nombre: String
    -apellido:
    -edad: Integer
}

enum EstadoSolicitudEliminacion {
    ACEPTADA,
    RECHAZADA,
    PENDIENTE
}

class ContenidoMultimedia {
    -nombre: String
    -ruta: String
    -formato: Formato
}

enum Formato {
    VIDEO
    AUDIO
    IMAGEN
}

class Hecho {
    -titulo: String
    -descripcion: String
    -categoria: Categoria
    -ubicacion: Ubicacion
    -etiquetas: <List>Etiqueta
    -fechaAcontecimiento: LocalDate
    -fechaCarga: LocalDate
    -origen: Origen
    -eliminado: Boolean
    -contenidoMultimedia: List<ContenidoMultimedia>
    +eliminar(): Integer
    +tieneContenidoMultimedia(): Boolean
    +estaEliminado(): Boolean
}

class ImportadorHechos {
    -rutaArchivo: String
    +cargarColeccion(Coleccion coleccion): Integer
}

class Etiqueta {
    -titulo: String
}

enum Origen {
    MANUAL
    DATASET
    CONTRIBUYENTE
}

class Categoria {
    -titulo: String
}

class Ubicacion {
    -latitud: String
    -longitud: String
}

class SolicitudEliminacion {
    -hecho: Hecho
    -fundamento: String
    -rechazada: Boolean
    -fechaResolucion: LocalDate
    +serAceptada(): Integer
    +serRechazada(): Integer
}

class Coleccion {
    -hechos: <List> Hecho
    -titulo: String
    -descripcion: String
    -criterios: <List> Criterio
    -fuentes: <List> Fuente
    +agregarHecho(hecho: Hecho): Integer
    +eliminarHecho(hecho: Hecho): Integer
    'Solo para representar overload
    +consultarHechos(): <List> Hecho
    +consultarHechos(filtros: <List> Filtros): <List> Hecho
    +recalcularHechos(): Integer

}

class Criterio{
    -elementosCriterio: <List> ElementoCriterio

    +cumpleCriterio(hecho: Hecho): Boolean
}

class RangoFechas {
    -fechaInicio: LocalDate
    -fechaFin: LocalDate
    +coincide(date: LocalDate): Boolean
}

interface ElementoCriterio{
    +coincide(algo): Boolean
}

class ElementoCriterioTitulo{
    -titulo: String
    +coincide(algo): Boolean
}

class EstrategiaDescripcion{
    -descripcion: String
    +coincide(algo): Boolean
}

class EstrategiaOrigen{
    -origen: Origen
    +coincide(algo): Boolean
}

class EstrategiaContenidoMultimedia{
    -tieneMultimedia: Boolean
    +coincide(algo): Boolean
}

class ElementoCriterioFechaAcontecimiento{
    -fechaAcontecimientoEntre: RangoFechas
    +coincide(algo): Boolean
}

class ElementoCriterioCategoria{
    -categoria: Categoria
    +coincide(algo): Boolean
}

class EstrategiaUbicacion{
    -ubicacion: Ubicacion
    +coincide(algo): Boolean
}

@enduml